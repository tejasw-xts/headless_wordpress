{
    "name": "yourname/smart-broken-link-fixer",
    "description": "AI-powered broken link detection and automatic fixing with smart redirects and suggestions for WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "keywords": [
        "wordpress",
        "plugin",
        "broken-links",
        "link-checker",
        "seo",
        "redirects",
        "ai"
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "wp-coding-standards/wpcs": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "SBLF\\": "includes/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=WordPress .",
        "phpcbf": "phpcbf --standard=WordPress ."
    }
}
